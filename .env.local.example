# Required
DATABASE_URL=postgresql://user:password@localhost:5432/gym_tracker
BETTER_AUTH_SECRET=your-random-secret-at-least-32-chars

# Google OAuth (Better Auth)
GOOGLE_CLIENT_ID=your-google-client-id
